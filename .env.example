# Errday Coach — free local AI via Ollama, no API key required
# For calendar actions (the coach adding events for you) use a tool-capable
# model such as qwen3:4b or llama3.1:8b. gemma3 can chat but cannot use tools.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# Local AI safety brake. Set AI_COACH_RATE_LIMIT_REQUESTS=0 to disable AI access.
AI_COACH_RATE_LIMIT_REQUESTS=10
AI_COACH_RATE_LIMIT_WINDOW_SECONDS=3600
