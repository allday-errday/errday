NEXT_PUBLIC_SUPABASE_URL=https://mocuomvbxnmdkbvjljdp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_8CJ7y__A21x1k_sMCKqvkw_1WF0QXEY
SUPABASE_SERVICE_ROLE_KEY=

# iPhone/Web Push. Generate with: npm run push:keys
NEXT_PUBLIC_WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com
CRON_SECRET=

# Optional native iOS wrapper target loaded by Capacitor.
CAPACITOR_SERVER_URL=https://errday.ch

# Errday Coach - free local AI via Ollama, no API key required
# For calendar actions (the coach adding events for you) use a tool-capable
# model such as qwen3:4b or llama3.1:8b. gemma3 can chat but cannot use tools.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
# Optional: use a separate vision-capable model for meal photo analysis.
OLLAMA_VISION_MODEL=

# Optional: use OpenAI for Errday AI. Keep this server-only; never prefix it
# with NEXT_PUBLIC_. gpt-5-mini handles both text meal estimates and food photos.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_VISION_MODEL=gpt-5-mini

# Optional: use Groq's OpenAI-compatible API instead of local Ollama.
GROQ_API_KEY=
GROQ_MODEL=
GROQ_VISION_MODEL=

# Local AI safety brake. Set AI_COACH_RATE_LIMIT_REQUESTS=0 to disable AI access.
AI_COACH_RATE_LIMIT_REQUESTS=10
AI_COACH_RATE_LIMIT_WINDOW_SECONDS=3600

# Errday is single-user: only these emails may sign up (comma-separated).
# Leave empty to allow open signups.
ALLOWED_SIGNUP_EMAILS=you@example.com
